# Combined .gitignore for a mono-repo containing Next.js/React (Node/Vite) frontend and Python backend
# Keeps node, build artifacts, environment files and common editor/OS cruft out of git

### Node / JavaScript / TypeScript ###
# Node modules
node_modules/

# Next.js build output
.next/

# Vite / bundler output
dist/
.vite/

# Build directories
out/
build/

# Optional npm cache
.npm/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
*.log

# Runtime data
*.pid
*.seed
*.pid.lock

# TypeScript cache
*.tsbuildinfo

# Local env files (do NOT commit secrets)
.env
.env.*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Misc caches
.cache/
.parcel-cache/

# Storybook
.storybook/

# Testing
/coverage/
.nyc_output/
.vitest/
node_modules/.cache/

### Python ###
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Virtual environments
venv/
ENV/
env/
.venv/
env.bak/
venv.bak/

# Pytest cache
.pytest_cache/

# Mypy
.mypy_cache/

# Coverage
.coverage
.coverage.*
htmlcov/

# PyInstaller
*.manifest
*.spec

# PEP 582; used by some tooling
__pypackages__/

# Python local settings
local_settings.py

# Jupyter Notebook
.ipynb_checkpoints

# Celery
celerybeat-schedule

# Python version managers
.python-version

### Editor / OS files ###
# VS Code
.vscode/

# JetBrains
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db

# Misc
*.swp
*~

### Other ###
# dotenv environment files sometimes present in subprojects
**/.env
**/.env.*.local

# Ignore build output from other tools
/.cache/

# Ensure lockfiles are kept (do not ignore package-lock.json, yarn.lock or pnpm-lock.yaml)
