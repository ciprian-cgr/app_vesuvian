{
  "identifier": "frontend_integration",
  "version": "1.0.0",
  "type": "integration_guide",

  "ai_context": {
    "purpose": "Frontend integration guide for React/Vue/Angular applications with the modular backend API",
    "use_when": [
      "Building web applications that consume the backend API",
      "Integrating authentication and user management",
      "Implementing real-time features",
      "Adding AI-powered functionality",
      "Managing teams and permissions"
    ],
    "dont_use_when": [
      "Building server-side applications",
      "Direct database access needed",
      "Backend-only functionality"
    ]
  },

  "integration": {
    "setup": {
      "base_url": "https://your-api-domain.com/api/v1",
      "authentication": "JWT Bearer tokens",
      "websockets": "wss://your-api-domain.com/ws",
      "required_headers": {
        "Content-Type": "application/json",
        "Authorization": "Bearer {token}"
      }
    },
    "dependencies": {
      "required": ["axios", "socket.io-client"],
      "recommended": ["react-query", "zustand", "react-hook-form"],
      "optional": ["framer-motion", "react-hot-toast"]
    }
  },

  "modules": {
    "auth": {
      "endpoints": {
        "POST /auth/login": "User login",
        "POST /auth/register": "User registration",
        "POST /auth/refresh": "Refresh access token",
        "POST /auth/logout": "User logout",
        "GET /auth/me": "Get current user"
      },
      "components": {
        "LoginForm": {
          "props": ["onSuccess", "redirectTo"],
          "state": ["email", "password", "loading", "error"],
          "example": "const LoginForm = ({ onSuccess }) => { /* implementation */ }"
        },
        "RegisterForm": {
          "props": ["onSuccess", "requireEmailVerification"],
          "state": ["formData", "loading", "errors"],
          "validation": "Use react-hook-form with yup/zod"
        },
        "AuthGuard": {
          "props": ["children", "fallback", "requiredRole"],
          "usage": "Wrap protected routes/components"
        }
      },
      "hooks": {
        "useAuth": {
          "returns": ["user", "login", "logout", "isAuthenticated", "loading"],
          "example": "const { user, login, logout } = useAuth();"
        },
        "useAuthToken": {
          "returns": ["token", "refreshToken", "isExpired"],
          "auto_refresh": true
        }
      },
      "storage": {
        "tokens": "localStorage or secure httpOnly cookies",
        "user_data": "Context/Redux store",
        "preferences": "localStorage"
      }
    },

    "users": {
      "endpoints": {
        "GET /users/profile": "Get user profile",
        "PUT /users/profile": "Update user profile",
        "POST /users/avatar": "Upload avatar",
        "GET /users/settings": "Get user settings",
        "PUT /users/settings": "Update user settings"
      },
      "components": {
        "UserProfile": {
          "props": ["userId", "editable", "onUpdate"],
          "features": ["avatar_upload", "profile_editing", "settings_management"]
        },
        "UserAvatar": {
          "props": ["user", "size", "fallback"],
          "sizes": ["xs", "sm", "md", "lg", "xl"]
        },
        "UserSettings": {
          "sections": ["profile", "notifications", "privacy", "security"],
          "validation": "Real-time validation with debouncing"
        }
      },
      "hooks": {
        "useUser": {
          "params": ["userId"],
          "returns": ["user", "loading", "error", "refetch"]
        },
        "useUserUpdate": {
          "returns": ["updateUser", "loading", "error"],
          "optimistic_updates": true
        }
      }
    },

    "teams": {
      "endpoints": {
        "GET /teams": "List user teams",
        "POST /teams": "Create team",
        "GET /teams/{id}": "Get team details",
        "PUT /teams/{id}": "Update team",
        "DELETE /teams/{id}": "Delete team",
        "POST /teams/{id}/members": "Add team member",
        "DELETE /teams/{id}/members/{userId}": "Remove team member"
      },
      "components": {
        "TeamList": {
          "props": ["onTeamSelect", "showCreateButton"],
          "features": ["search", "filtering", "pagination"]
        },
        "TeamCard": {
          "props": ["team", "actions", "showMembers"],
          "actions": ["edit", "delete", "view_members"]
        },
        "TeamMembersList": {
          "props": ["teamId", "canManageMembers"],
          "features": ["role_management", "invite_members", "remove_members"]
        },
        "CreateTeamModal": {
          "props": ["isOpen", "onClose", "onSuccess"],
          "form_fields": ["name", "description", "visibility"]
        }
      },
      "hooks": {
        "useTeams": {
          "returns": ["teams", "loading", "error", "refetch"]
        },
        "useTeam": {
          "params": ["teamId"],
          "returns": ["team", "members", "loading", "error"]
        },
        "useTeamMutations": {
          "returns": ["createTeam", "updateTeam", "deleteTeam", "addMember", "removeMember"]
        }
      }
    },

    "ai_integration": {
      "endpoints": {
        "POST /ai/generate": "Generate text",
        "POST /ai/embeddings": "Generate embeddings",
        "POST /ai/conversations": "Create conversation",
        "POST /ai/conversations/{id}/messages": "Send message",
        "GET /ai/models": "List available models",
        "GET /ai/usage": "Get usage statistics"
      },
      "components": {
        "AITextGenerator": {
          "props": ["model", "onGenerate", "placeholder"],
          "features": ["model_selection", "parameter_tuning", "streaming_response"]
        },
        "ChatInterface": {
          "props": ["conversationId", "systemPrompt"],
          "features": ["message_history", "typing_indicators", "message_reactions"]
        },
        "AIModelSelector": {
          "props": ["selectedModel", "onModelChange", "filterByType"],
          "displays": ["model_name", "capabilities", "cost_info"]
        },
        "UsageMetrics": {
          "props": ["userId", "teamId", "timeRange"],
          "charts": ["requests_over_time", "cost_breakdown", "model_usage"]
        }
      },
      "hooks": {
        "useAIGenerate": {
          "params": ["model", "options"],
          "returns": ["generate", "loading", "error", "result"]
        },
        "useConversation": {
          "params": ["conversationId"],
          "returns": ["messages", "sendMessage", "loading", "error"]
        },
        "useAIModels": {
          "returns": ["models", "loading", "error"]
        }
      },
      "real_time": {
        "events": ["message_received", "generation_progress", "usage_updated"],
        "websocket_namespace": "/ai"
      }
    },

    "file_storage": {
      "endpoints": {
        "POST /files/upload": "Upload file",
        "GET /files/{id}": "Get file info",
        "GET /files/{id}/download": "Download file",
        "DELETE /files/{id}": "Delete file"
      },
      "components": {
        "FileUpload": {
          "props": ["accept", "maxSize", "multiple", "onUpload"],
          "features": ["drag_drop", "progress_bar", "preview", "validation"]
        },
        "FileList": {
          "props": ["files", "onDelete", "onDownload"],
          "features": ["thumbnails", "file_info", "bulk_actions"]
        },
        "ImagePreview": {
          "props": ["fileId", "alt", "size"],
          "features": ["lazy_loading", "zoom", "fullscreen"]
        }
      },
      "hooks": {
        "useFileUpload": {
          "returns": ["upload", "progress", "error", "cancel"]
        },
        "useFiles": {
          "params": ["folderId", "filters"],
          "returns": ["files", "loading", "error", "refetch"]
        }
      }
    },

    "push_notifications": {
      "endpoints": {
        "POST /notifications/subscribe": "Subscribe to push notifications",
        "GET /notifications": "Get user notifications",
        "PUT /notifications/{id}/read": "Mark as read"
      },
      "components": {
        "NotificationCenter": {
          "props": ["position", "maxVisible"],
          "features": ["real_time_updates", "mark_as_read", "actions"]
        },
        "NotificationItem": {
          "props": ["notification", "onAction"],
          "types": ["info", "success", "warning", "error"]
        },
        "PushNotificationSetup": {
          "props": ["onPermissionGranted"],
          "features": ["permission_request", "service_worker_registration"]
        }
      },
      "hooks": {
        "useNotifications": {
          "returns": ["notifications", "unreadCount", "markAsRead", "subscribe"]
        },
        "usePushNotifications": {
          "returns": ["isSupported", "isSubscribed", "subscribe", "unsubscribe"]
        }
      },
      "service_worker": {
        "required": true,
        "file": "public/sw.js",
        "features": ["background_sync", "offline_notifications"]
      }
    },

    "billing": {
      "endpoints": {
        "GET /billing/plans": "Get available plans",
        "GET /billing/subscription": "Get current subscription",
        "POST /billing/subscribe": "Subscribe to plan",
        "POST /billing/cancel": "Cancel subscription",
        "GET /billing/invoices": "Get invoices"
      },
      "components": {
        "PricingTable": {
          "props": ["plans", "currentPlan", "onSelectPlan"],
          "features": ["feature_comparison", "billing_toggle", "popular_badge"]
        },
        "SubscriptionStatus": {
          "props": ["subscription"],
          "displays": ["current_plan", "next_billing", "usage_limits"]
        },
        "PaymentForm": {
          "props": ["planId", "onSuccess", "onError"],
          "integration": "Stripe Elements or similar"
        },
        "InvoiceList": {
          "props": ["invoices", "onDownload"],
          "features": ["filtering", "search", "download_pdf"]
        }
      },
      "hooks": {
        "useBilling": {
          "returns": ["subscription", "plans", "invoices", "loading"]
        },
        "useSubscription": {
          "returns": ["subscribe", "cancel", "updatePayment", "loading"]
        }
      }
    },

    "webhooks": {
      "endpoints": {
        "GET /webhooks": "List webhooks",
        "POST /webhooks": "Create webhook",
        "PUT /webhooks/{id}": "Update webhook",
        "DELETE /webhooks/{id}": "Delete webhook",
        "POST /webhooks/{id}/test": "Test webhook"
      },
      "components": {
        "WebhookList": {
          "props": ["webhooks", "onEdit", "onDelete", "onTest"],
          "features": ["status_indicators", "delivery_logs", "retry_failed"]
        },
        "WebhookForm": {
          "props": ["webhook", "onSave"],
          "fields": ["url", "events", "secret", "active"]
        },
        "WebhookLogs": {
          "props": ["webhookId"],
          "features": ["delivery_status", "response_details", "retry_button"]
        }
      },
      "hooks": {
        "useWebhooks": {
          "returns": ["webhooks", "loading", "error", "refetch"]
        },
        "useWebhookMutations": {
          "returns": ["create", "update", "delete", "test"]
        }
      }
    }
  },

  "patterns": {
    "state_management": {
      "global_state": "Use Zustand or Redux Toolkit for app-wide state",
      "server_state": "Use React Query or SWR for API data",
      "form_state": "Use React Hook Form for complex forms",
      "local_state": "Use useState for component-specific state"
    },
    "error_handling": {
      "api_errors": "Centralized error handling with interceptors",
      "user_feedback": "Toast notifications for user actions",
      "error_boundaries": "Catch and display component errors",
      "retry_logic": "Automatic retry for failed requests"
    },
    "performance": {
      "code_splitting": "Lazy load routes and heavy components",
      "memoization": "Use React.memo and useMemo appropriately",
      "virtualization": "Use react-window for large lists",
      "image_optimization": "Lazy loading and responsive images"
    },
    "accessibility": {
      "keyboard_navigation": "Full keyboard support",
      "screen_readers": "Proper ARIA labels and roles",
      "color_contrast": "WCAG AA compliance",
      "focus_management": "Logical focus flow"
    }
  },

  "real_time": {
    "websocket_connection": {
      "url": "wss://your-api-domain.com/ws",
      "authentication": "Send JWT token on connection",
      "reconnection": "Automatic reconnection with exponential backoff"
    },
    "events": {
      "user_events": ["user_updated", "user_online", "user_offline"],
      "team_events": ["team_updated", "member_added", "member_removed"],
      "ai_events": ["generation_complete", "conversation_updated"],
      "notification_events": ["notification_received", "notification_read"]
    },
    "implementation": {
      "library": "socket.io-client",
      "hook": "useSocket or useWebSocket",
      "context": "WebSocketProvider for app-wide access"
    }
  },

  "testing": {
    "unit_tests": {
      "framework": "Jest + React Testing Library",
      "coverage": "Aim for 80%+ coverage",
      "mocking": "Mock API calls and external dependencies"
    },
    "integration_tests": {
      "framework": "Cypress or Playwright",
      "scenarios": "User workflows and critical paths",
      "api_mocking": "Mock backend responses"
    },
    "e2e_tests": {
      "framework": "Cypress or Playwright",
      "environments": "Staging environment testing",
      "data": "Use test data fixtures"
    }
  },

  "deployment": {
    "build": {
      "command": "npm run build",
      "output": "dist/ or build/",
      "optimization": "Tree shaking and minification"
    },
    "hosting": {
      "static": "Vercel, Netlify, or AWS S3",
      "spa": "Configure routing for single-page apps",
      "cdn": "Use CDN for static assets"
    },
    "environment": {
      "variables": ["REACT_APP_API_URL", "REACT_APP_WS_URL", "REACT_APP_STRIPE_KEY"],
      "configuration": "Different configs per environment"
    }
  }
}
