{
  "identifier": "schemas",
  "version": "1.0.0",
  "type": "module",

  "ai_context": {
    "purpose": "Pydantic schemas for API request/response validation and serialization",
    "use_when": [
      "Validating API request data",
      "Serializing API responses",
      "Type checking input/output",
      "Documentation generation"
    ],
    "dont_use_when": [
      "Database model definitions (use models)",
      "Internal data processing (use Python dataclasses)",
      "Business logic validation (use services)"
    ]
  },

  "integration": {
    "backend": {
      "import": "from app.schemas.user import UserCreate, UserUpdate",
      "request": "def create_user(user_data: UserCreate):",
      "response": "return User.from_orm(db_user)",
      "validation": "Automatic with FastAPI dependency injection"
    },
    "api": {
      "endpoint": "Use schema as parameter type in FastAPI routes",
      "docs": "Schemas auto-generate OpenAPI documentation",
      "serialization": "from_attributes = True for ORM conversion"
    }
  },

  "patterns": {
    "follows": [
      "Base schema with common fields",
      "Create/Update/Response schema variants",
      "Pydantic v2 syntax and features",
      "Optional fields for updates"
    ],
    "enforces": [
      "Email validation with EmailStr",
      "Field validation with Pydantic validators",
      "Exclude sensitive fields from responses",
      "Proper type hints for all fields"
    ]
  },

  "dependencies": {
    "requires": ["pydantic", "email-validator"],
    "optional": ["pydantic-settings"],
    "conflicts": []
  },

  "examples": {
    "base_schema": {
      "code": "class ItemBase(BaseModel):\n    name: str\n    description: Optional[str] = None\n\nclass ItemCreate(ItemBase):\n    pass\n\nclass Item(ItemBase):\n    id: int\n    created_at: datetime\n    \n    class Config:\n        from_attributes = True"
    }
  }
}
