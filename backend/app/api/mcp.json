{
  "identifier": "api",
  "version": "1.0.0",
  "type": "module",

  "ai_context": {
    "purpose": "REST API endpoints with FastAPI routing, validation, and documentation",
    "use_when": [
      "Creating HTTP endpoints",
      "API versioning",
      "Request/response handling",
      "Authentication/authorization"
    ],
    "dont_use_when": [
      "Business logic implementation (use services)",
      "Database operations (use repositories)",
      "Background tasks (use separate task module)"
    ]
  },

  "integration": {
    "backend": {
      "router": "from fastapi import APIRouter; router = APIRouter()",
      "endpoint": "@router.get('/path') async def endpoint():",
      "dependency": "Use Depends() for service injection",
      "auth": "Use verify_token dependency for protection"
    },
    "versioning": {
      "structure": "api/v1/, api/v2/ for versions",
      "router": "Include routers with version prefix",
      "deprecation": "Mark old versions in OpenAPI docs"
    }
  },

  "patterns": {
    "follows": [
      "RESTful API design",
      "FastAPI dependency injection",
      "Automatic OpenAPI documentation",
      "Consistent error responses"
    ],
    "enforces": [
      "HTTP status codes standards",
      "Request/response schema validation",
      "Authentication on protected endpoints",
      "Proper error handling"
    ]
  },

  "dependencies": {
    "requires": ["fastapi", "app.services", "app.schemas", "app.core.security"],
    "optional": ["app.core.rate_limiting"],
    "conflicts": []
  },

  "examples": {
    "new_endpoint": {
      "code": "@router.post('/', response_model=Product)\nasync def create_product(\n    product_data: ProductCreate,\n    db: AsyncSession = Depends(get_db),\n    current_user: dict = Depends(verify_token)\n):\n    service = ProductService(db)\n    return await service.create_product(product_data)"
    }
  }
}
