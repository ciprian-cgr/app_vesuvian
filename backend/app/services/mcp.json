{
  "identifier": "services",
  "version": "1.0.0",
  "type": "module",

  "ai_context": {
    "purpose": "Business logic layer orchestrating repositories and implementing domain rules",
    "use_when": [
      "Complex business operations",
      "Multi-repository transactions",
      "Domain rule enforcement",
      "External service integration"
    ],
    "dont_use_when": [
      "Simple CRUD operations (use repositories directly)",
      "API request/response handling (use endpoints)",
      "Database schema definition (use models)"
    ]
  },

  "integration": {
    "backend": {
      "import": "from app.services.user import UserService",
      "usage": "service = UserService(db_session)",
      "dependency": "Inject into FastAPI endpoints",
      "repositories": "Services compose multiple repositories"
    },
    "business_logic": {
      "validation": "Implement domain-specific validation",
      "workflows": "Orchestrate multi-step operations",
      "external_apis": "Handle third-party integrations"
    }
  },

  "patterns": {
    "follows": [
      "Service layer pattern",
      "Dependency injection with repositories",
      "Domain-driven design principles",
      "Error handling with HTTP exceptions"
    ],
    "enforces": [
      "Business rule validation",
      "Consistent error responses",
      "Transaction boundaries",
      "Logging for audit trails"
    ]
  },

  "dependencies": {
    "requires": ["fastapi", "app.repositories", "app.schemas"],
    "optional": ["external-apis", "background-tasks"],
    "conflicts": []
  },

  "examples": {
    "new_service": {
      "code": "class ProductService(LoggerMixin):\n    def __init__(self, db: AsyncSession):\n        self.repository = ProductRepository(db)\n    \n    async def create_product(self, product_data: ProductCreate) -> Product:\n        # Business logic validation\n        if product_data.price <= 0:\n            raise HTTPException(400, 'Price must be positive')\n        \n        return await self.repository.create(product_data.dict())"
    }
  }
}
