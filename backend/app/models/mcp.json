{
  "identifier": "models",
  "version": "1.0.0",
  "type": "module",

  "ai_context": {
    "purpose": "Database models and ORM definitions using SQLAlchemy",
    "use_when": [
      "Defining database schema",
      "Creating new entities",
      "Setting up relationships between tables",
      "Adding database constraints"
    ],
    "dont_use_when": [
      "API request/response validation (use schemas)",
      "Business logic implementation (use services)",
      "Database queries (use repositories)"
    ]
  },

  "integration": {
    "backend": {
      "import": "from app.models.user import User",
      "base_class": "from app.core.database import Base",
      "create_model": "class NewModel(Base): __tablename__ = 'table_name'",
      "relationships": "Use SQLAlchemy relationship() for foreign keys"
    },
    "database": {
      "migration": "alembic revision --autogenerate -m 'description'",
      "apply": "alembic upgrade head",
      "tables": "Auto-created from Base.metadata.create_all()"
    }
  },

  "patterns": {
    "follows": [
      "SQLAlchemy declarative base",
      "Timestamp fields (created_at, updated_at)",
      "Primary key as 'id' integer",
      "Proper indexing on lookup fields"
    ],
    "enforces": [
      "Table names in snake_case",
      "Non-nullable fields explicitly marked",
      "Unique constraints on business keys",
      "Timezone-aware datetime fields"
    ]
  },

  "dependencies": {
    "requires": ["sqlalchemy", "app.core.database"],
    "optional": ["alembic"],
    "conflicts": []
  },

  "examples": {
    "new_model": {
      "code": "class Product(Base):\n    __tablename__ = 'products'\n    id = Column(Integer, primary_key=True)\n    name = Column(String, nullable=False)\n    price = Column(Float, nullable=False)\n    created_at = Column(DateTime(timezone=True), server_default=func.now())"
    }
  }
}
