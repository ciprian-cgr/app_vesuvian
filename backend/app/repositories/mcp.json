{
  "identifier": "repositories",
  "version": "1.0.0",
  "type": "module",

  "ai_context": {
    "purpose": "Data access layer implementing repository pattern with async SQLAlchemy",
    "use_when": [
      "Database CRUD operations",
      "Complex database queries",
      "Data access abstraction",
      "Transaction management"
    ],
    "dont_use_when": [
      "Business logic implementation (use services)",
      "API request handling (use endpoints)",
      "Data validation (use schemas)"
    ]
  },

  "integration": {
    "backend": {
      "import": "from app.repositories.user import UserRepository",
      "usage": "repo = UserRepository(db_session)",
      "base": "Inherit from BaseRepository[ModelType]",
      "interface": "Implement I{Entity}Repository interface"
    },
    "database": {
      "session": "Requires AsyncSession dependency",
      "queries": "Use SQLAlchemy select/update/delete",
      "transactions": "Auto-handled with session commit/rollback"
    }
  },

  "patterns": {
    "follows": [
      "Repository pattern with interfaces",
      "Generic base repository with CRUD",
      "Async/await for all database operations",
      "Error handling with logging"
    ],
    "enforces": [
      "Type safety with Generic[ModelType]",
      "Consistent error handling",
      "Transaction rollback on errors",
      "Logging for debugging"
    ]
  },

  "dependencies": {
    "requires": ["sqlalchemy", "app.core.database", "app.core.logging"],
    "optional": [],
    "conflicts": []
  },

  "examples": {
    "new_repository": {
      "code": "class ProductRepository(BaseRepository[Product]):\n    def __init__(self, db: AsyncSession):\n        super().__init__(Product, db)\n    \n    async def get_by_name(self, name: str) -> Optional[Product]:\n        result = await self.db.execute(\n            select(Product).where(Product.name == name)\n        )\n        return result.scalar_one_or_none()"
    }
  }
}
